---
import { Image, Picture } from "astro:assets";
import * as path from "node:path";
import type { ImageMetadata } from "astro";
import type { ImageFormat, ResponsiveImageLayout } from "@/types/config";
import {
	getFallbackFormat,
	getImageFormats,
	getImageQuality,
	shouldAddNoReferrer,
} from "@/utils/image-utils";
import { getLqipProps } from "@/utils/lqip-utils";
import { url } from "@/utils/url-utils";

interface Props {
	id?: string;
	src: string;
	class?: string;
	alt?: string;
	position?: string;
	basePath?: string;
	loading?: "lazy" | "eager";
	fetchpriority?: "high" | "low" | "auto";
	// 响应式图像属性
	layout?: ResponsiveImageLayout;
	usePicture?: boolean;
	formats?: ImageFormat[];
	widths?: number[];
	sizes?: string;
	quality?: number;
	fadeIn?: boolean;
}

const {
	id,
	src,
	alt,
	position = "center",
	basePath = "/",
	loading = "lazy",
	fetchpriority = "auto",
	layout = "constrained",
	usePicture = true,
	formats = getImageFormats(),
	widths,
	sizes,
	quality = getImageQuality(),
	fadeIn = true,
} = Astro.props;

const fallbackFormat = getFallbackFormat();
const className = Astro.props.class;

const isLocal = !(
	src.startsWith("/") ||
	src.startsWith("http") ||
	src.startsWith("https") ||
	src.startsWith("data:")
);
const isPublic = src.startsWith("/");
const isGif = src.toLowerCase().endsWith(".gif");

// TODO temporary workaround for images dynamic import
// https://github.com/withastro/astro/issues/3373
let img: ImageMetadata | null = null;
let gifUrl: string | null = null;
if (isLocal) {
	const normalizedPath = path
		.normalize(path.join("../../", basePath, src))
		.replace(/\\/g, "/");
	if (isGif) {
		// GIF: 用 ?url 导入绕过 Astro 图片优化，保留原始画质和动画
		const gifFiles = import.meta.glob("../../**/*.gif", {
			query: "?url",
			import: "default",
		});
		const file = gifFiles[normalizedPath];
		if (!file) {
			console.error(
				`
[ERROR] GIF file not found: ${normalizedPath.replace("../../", "src/")}`,
			);
		} else {
			gifUrl = await file();
		}
	} else {
		// 静态图片: 用 ImageMetadata 优化（avif/webp 压缩）
		const files = import.meta.glob<ImageMetadata>(
			"../../**/*.{png,jpg,jpeg,webp,avif}",
			{
				import: "default",
			},
		);
		const file = files[normalizedPath];
		if (!file) {
			console.error(
				`
[ERROR] Image file not found: ${normalizedPath.replace("../../", "src/")}`,
			);
		} else {
			img = await file();
		}
	}
}
const imageClass = fadeIn
	? "w-full h-full object-cover opacity-0 transition-opacity duration-500 ease-out"
	: "w-full h-full object-cover";
const imageStyle = `object-position: ${position}`;

// 检查是否需要添加 referrerpolicy（仅对非本地图片）
const fullSrc = isPublic ? url(src) : src;
const referrerPolicy =
	!isLocal && shouldAddNoReferrer(fullSrc) ? "no-referrer" : undefined;

// 构建响应式图像属性
const responsiveProps = {
	...(layout && { layout }),
	...(widths && { widths }),
	...(sizes && { sizes }),
	...(quality && { quality }),
};

// LQIP 渐变占位
const lqipProps = isLocal
	? getLqipProps(src, basePath)
	: isPublic
		? getLqipProps(src, basePath, true)
		: getLqipProps(src);
---
<div id={id} class:list={[className, 'overflow-hidden relative']}>
    {fadeIn && <div class="lqip-placeholder absolute inset-0 pointer-events-none" style={lqipProps.style} aria-hidden="true"></div>}
    <div class="transition absolute inset-0 dark:bg-black/10 pointer-events-none"></div>
    {isLocal && gifUrl && (
        <img src={gifUrl} alt={alt || ""} class={imageClass} style={imageStyle} loading={loading} fetchpriority={fetchpriority} decoding="async" />
    )}
    {isLocal && img && !isGif && usePicture && (
        <Picture
            src={img}
            alt={alt || ""}
            class={imageClass}
            style={imageStyle}
            loading={loading}
            fetchpriority={fetchpriority}
            formats={formats}
            fallbackFormat={fallbackFormat}
            {...responsiveProps}
        />
    )}
    {isLocal && img && !isGif && !usePicture && (
        <Image
            src={img}
            alt={alt || ""}
            class={imageClass}
            style={imageStyle}
            loading={loading}
            fetchpriority={fetchpriority}
            {...responsiveProps}
        />
    )}
    {!isLocal && <img src={isPublic ? url(src) : src} alt={alt || ""} class={imageClass} style={imageStyle} loading={loading} fetchpriority={fetchpriority} referrerpolicy={referrerPolicy} />}
</div>
